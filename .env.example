# Copy to .env and fill in a real key to enable daily /v1/models fetching.
# The server runs fine without it — it just serves the last committed snapshot.
OPENAI_API_KEY=sk-...

# Optional: override the daily fetch interval (seconds). Default 86400 (24h).
# FETCH_INTERVAL_SECONDS=86400

# Optional: override the server port. Default 3323.
# PORT=3323
